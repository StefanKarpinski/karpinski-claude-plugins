#!/usr/bin/env python3
"""cmdline <pid> — print a process's argv as JSONL.

Output: JSONL. One object per argv element, in order, with an `index`
field (0-based) and either a `value` or a `redacted` field (or both,
for the partial-redact `--flag=value` case):

  {"index": 0, "value": "my-app"}
  {"index": 1, "value": "--token"}
  {"index": 2, "redacted": "secret flag"}                   # next-token redact
  {"index": 3, "value": "--port"}
  {"index": 4, "value": "8080"}
  {"index": 5, "value": "--api-key=", "redacted": "secret flag"}   # partial
  {"index": 6, "redacted": "secret value"}                   # entropy / shape

Redaction (two layers; both fire by default):

1. SECRET-FLAG redaction. Tokens following a credential-flag pattern
   (`--password`, `--passwd`, `--pass`, `--secret`, `--token`,
   `--bearer`, `--api-key`, `--access-token`, `--id-token`,
   `--auth-token`, `--client-secret`, `--cookie`, `--session`,
   `--private-key`, `--key-file`, `-p`, `-k`) get `"redacted": "secret
   flag"`. The `--flag=value` form keeps the flag prefix (including
   the `=`) in `value` and adds `"redacted": "secret flag"` for the
   value half.

2. SECRET-VALUE redaction. Each remaining argv element is checked
   against the shared `looks_like_secret_value` heuristic (known
   credential formats: sk-..., ghp_..., AKIA..., JWT, PEM private
   keys, etc.; plus a length+charset+entropy gate). Matches get
   `"redacted": "secret value"`. This catches credentials passed as
   positional arguments (e.g. `my-app sk-ant-api03-...`).

To emit raw argv (only when you have a real reason), pass `--unsafe`.
The flag appears in the transcript so the bypass is auditable; every
element then prints as `{"index": N, "value": "..."}`.

See _secret_heuristics.py for the shared value-shape detector.
"""

import json
import os
import re
import sys

_HERE = os.path.dirname(os.path.realpath(__file__))
sys.path.insert(0, os.path.join(_HERE, "..", "lib"))
from _secret_heuristics import looks_like_secret_value  # noqa: E402


# Argv flags that historically introduce a secret as the next token.
# Match is whole-token, case-insensitive.
SECRET_FLAG_PATTERN = re.compile(
    r"^(-[pPkK]|"
    r"--password|--passwd|--pass|"
    r"--secret|--token|--bearer|"
    r"--api[-_]?key|--auth[-_]?token|--access[-_]?token|--id[-_]?token|"
    r"--client[-_]?secret|"
    r"--cookie|--session|"
    r"--private[-_]?key|--key[-_]?file)$",
    re.IGNORECASE,
)

SECRET_FLAG_EQ_PATTERN = re.compile(
    r"^(-[pPkK]|"
    r"--password|--passwd|--pass|"
    r"--secret|--token|--bearer|"
    r"--api[-_]?key|--auth[-_]?token|--access[-_]?token|--id[-_]?token|"
    r"--client[-_]?secret|"
    r"--cookie|--session|"
    r"--private[-_]?key|--key[-_]?file)=",
    re.IGNORECASE,
)


def redact_argv_jsonl(argv: list[str]) -> list[dict]:
    out: list[dict] = []
    consume_next = False
    for i, arg in enumerate(argv):
        rec: dict = {"index": i}
        if consume_next:
            rec["redacted"] = "secret flag"
            consume_next = False
            out.append(rec)
            continue
        if SECRET_FLAG_PATTERN.match(arg):
            rec["value"] = arg
            consume_next = True
            out.append(rec)
            continue
        m = SECRET_FLAG_EQ_PATTERN.match(arg)
        if m:
            rec["value"] = m.group(0)  # "--flag=" — keep the prefix, redact the rest
            rec["redacted"] = "secret flag"
            out.append(rec)
            continue
        if looks_like_secret_value(arg):
            rec["redacted"] = "secret value"
            out.append(rec)
            continue
        rec["value"] = arg
        out.append(rec)
    return out


def main() -> int:
    args = sys.argv[1:]
    if not args or args[0] in {"-h", "--help"}:
        sys.stderr.write(__doc__)
        return 2

    unsafe = False
    if "--unsafe" in args:
        unsafe = True
        args = [a for a in args if a != "--unsafe"]

    if len(args) != 1:
        sys.stderr.write("expected a single pid argument\n")
        return 2

    pid = args[0]
    try:
        with open(f"/proc/{pid}/cmdline", "rb") as f:
            data = f.read()
    except FileNotFoundError:
        sys.stderr.write(f"no such process: {pid}\n")
        return 1
    except PermissionError:
        sys.stderr.write(f"permission denied reading cmdline of pid {pid}\n")
        return 1

    argv = [a.decode("utf-8", errors="replace") for a in data.split(b"\0") if a]

    if unsafe:
        records = [{"index": i, "value": a} for i, a in enumerate(argv)]
    else:
        records = redact_argv_jsonl(argv)

    for rec in records:
        print(json.dumps(rec))
    return 0


if __name__ == "__main__":
    sys.exit(main())
